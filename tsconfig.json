{
  // 类型检查专用（tsc --noEmit）——不产出任何文件；运行时仍由 node 直接 strip-types + esbuild bundle。
  // 本轮只把 store 深模块（src/store/**）纳入 strict 检查（被 Uint8Array/Blob 类型 bug 雷击两次）；
  // 其余 src/ 暂不检（增量推进，别一次铺满全仓引爆历史错误）。
  "compilerOptions": {
    "strict": true,
    "noEmit": true,

    // Node 24 默认 strip-types 跑 .ts；本仓约定 import 写 .ts 扩展名（见 app.js / test/*.mjs）。
    // module:preserve + bundler 解析 + allowImportingTsExtensions 才能让 tsc 认 "./x.ts" 这种 specifier。
    "module": "preserve",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "target": "es2022",
    "lib": ["es2022", "dom", "dom.iterable"],

    // store 边界会 import 到仓里未类型化的 .js（../ora.js / ../session.js / ../storage.js）：
    // allowJs 让它们能被解析，checkJs:false 让它们不报错（松边界，类型按推断/any 走）。
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,

    // verbatimModuleSyntax：强制 type-only import 写 `import type`，否则 node strip-types 会把
    // 纯类型 import 当运行时 import 留下 → 运行时「does not provide an export」。是 node 兼容的硬约束。
    "verbatimModuleSyntax": true,

    // 不拉 @types/node（没装）；只认上面 lib。
    "types": [],
    "forceConsistentCasingInFileNames": true
  },
  // include = 受 tsc 检查的显式准入名单（不是「全 src/」）。store 深模块 + 逐批迁入的叶子。
  // 加新文件进来 = 把它纳入硬门：从此它的类型契约被持续验证（见 docs/ts-migration.md）。
  // batch 1（v294，2026-06-19）：11 个纯·已测·低耦合叶子（无 DOM 副作用 / 无领域写）。
  // batch 2（v295，2026-06-19）：AppContext seam（组合根装配契约）+ 首批 initX 消费方入门。
  // batch 3（v296，2026-06-19）：app 层基础叶子（surfaces/signals/sheets/anchored-popup/session-name）
  //   + color-panel 消费方（带 ui/color-wheel·color-model 级联）。
  // batch 4（v297，2026-06-19）：session-state + editor-state hub（解锁多数消费方闭包；EditorRuntimeState 收紧）。
  // batch 11（v304，2026-06-19）：最后一簇 AppContext 消费方 → consumer rollout 完成。
  // batch 12（v305，2026-06-19）：非 ctx 消费方簇（brush-rack keystone + brush-io/current-brush/
  //   dial-controls/pwa-shell/dev-console/save-status）+ 新 brush-types（brush 形状单一真源）。
  // batch 13（v306，2026-06-19）：引擎接缝 .js→.ts 大批转换（doc/board/input 手感核心 + edit-mode/
  //   history/pixel-edit/session/ora）+ gallery UI 簇灭 any。引擎类型从 inferred-any 收成真类型，
  //   级联到消费方的 boundary mismatch 用 cast 收口（行为零变更，388 测试守门）。
  // batch 14（v308，2026-06-19）：二级引擎 .js→.ts（brush/liquify/filter-brush/stroke-smoother/
  //   stroke-input-smooth/lasso/selection/layer-composite/floating-transform/resample/bitmap）。
  //   selection.ts 真类型 → doc.ts 弃本地 SelectionLike 镜像直接 import Selection。
  // batch 15（v312，2026-06-20）：支持/功能叶 .js→.ts（filters/storage/config/crypto-*/brushes/
  //   exporters/zip/sevenzip/cloud-thumbs*/enc-thumbs/reference/palette/psd/smooth-config/panel-state）。
  //   剩 app-store.js（红线门面）+ app.js（god-file 根）+ version.js（构建 sed 路径，保 .js）。
  "include": [
    "src/app.ts",
    "src/app-store.ts",
    "src/ui/brush-settings.ts",
    "src/ui/brush-settings-model.ts",
    "src/ui/brush-size.ts",
